{
  "name": "live-trains-finland",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/server": "^11.11.0",
    "@emotion/styled": "^11.14.1",
    "@mui/lab": "9.0.0-beta.2",
    "@mui/material": "^9.0.0",
    "@mui/material-nextjs": "^9.0.0",
    "@tanstack/react-query": "^5.99.2",
    "@turf/distance": "^7.3.5",
    "@types/autosuggest-highlight": "^3.2.3",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autosuggest-highlight": "^3.3.4",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "deck.gl": "^9.3.1",
    "graphql": "^16.13.2",
    "graphql-request": "^7.4.0",
    "hsl-map-style": "github:HSLdevcom/hsl-map-style#master",
    "i18next": "^26.0.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.5",
    "lodash": "^4.18.1",
    "maplibre-gl": "^5.23.0",
    "mdi-material-ui": "^8.0.0",
    "mqtt": "^5.15.1",
    "next": "16.2.4",
    "nuqs": "^2.8.9",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-i18next": "^17.0.4",
    "react-map-gl": "^8.1.1",
    "react-reverse-portal": "^2.3.0",
    "react-svg": "^17.2.4",
    "react-transition-group": "^4.4.5",
    "typescript": "^6.0.3",
    "use-local-storage-state": "^19.5.0",
    "zustand": "^5.0.12"
  },
  "scripts": {
    "dev": "next dev",
    "build": "npm run extract-tiles && next build && npm run build-service-worker",
    "build-service-worker": "ts-node --project tools/tsconfig.json tools/buildServiceWorker.ts",
    "start": "next start",
    "test": "jest",
    "lint": "eslint ./src --max-warnings=0",
    "lint:fix": "eslint ./src --fix",
    "pretype-check": "next typegen",
    "type-check": "tsc --noEmit && tsc --noEmit -p tools",
    "extract-tiles-railway-tracks": "ts-node --project tools/tsconfig.json tools/extractMbtiles.ts --input=./data/railway_tracks.mbtiles --output=./public/tiles/railway_tracks",
    "extract-tiles-railway-platforms": "ts-node --project tools/tsconfig.json tools/extractMbtiles.ts --input=./data/railway_platforms.mbtiles --output=./public/tiles/railway_platforms",
    "extract-tiles": "npm run extract-tiles-railway-tracks && npm run extract-tiles-railway-platforms",
    "digitransit-codegen": "graphql-codegen --require dotenv/config --config digitransit-codegen.yml dotenv_config_path=.env.local",
    "digitraffic-codegen": "graphql-codegen --config digitraffic-codegen.yml",
    "gql-codegen": "npm run digitransit-codegen && npm run digitraffic-codegen",
    "generate-station-line-km-location-data": "ts-node --project tools/tsconfig.json tools/generateStationLineKmLocationData.ts",
    "generate-station-platform-data": "ts-node --project tools/tsconfig.json tools/generateStationPlatformData.ts",
    "prestart": "npm run gql-codegen",
    "prepare": "is-ci || husky"
  },
  "browserslist": [
    "defaults",
    "not ie 11"
  ],
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260420.1",
    "@graphql-codegen/cli": "^6.3.1",
    "@graphql-codegen/client-preset": "^4.5.1",
    "@svgr/webpack": "^8.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^16.4.0",
    "ts-node": "^10.9.2",
    "workbox-build": "^7.4.0",
    "workbox-core": "^7.4.0",
    "workbox-expiration": "^7.4.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": "eslint --max-warnings=0 ./src"
  }
}
